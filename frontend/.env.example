# Joule: Zero Point - Frontend Configuration
# Central Intelligence Protocol

# Unified Quantum API Access Point
# In Docker (Nginx proxy): /api/v1
# Local (Direct): http://localhost:3000/api/v1
VITE_API_URL=/api/v1

# Optional: direct backend endpoint used only for multipart uploads.
# Useful in production when reverse-proxy rewrites break file uploads.
# Example: https://joulezeropoint.simonecamerano.dev/api/v1
VITE_UPLOAD_API_URL=
