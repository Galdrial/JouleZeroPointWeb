{
  "CORE_MECHANICS": {
    "SETUP": {
      "INITIAL_IT": 20,
      "INITIAL_TP": 0,
      "INITIAL_ET": 3,
      "HAND_SIZE": 5
    },
    "VALUES": {
      "PEP": "Energy Pressure (Attack)",
      "RP": "Present Resistance (Defense)",
      "ET": "Temporal Energy (Cost)",
      "IT": "Temporal Integrity (Life)"
    }
  },
  "PHASE_1_SLITTAMENTO": {
    "RULE_FLOW_NORMAL": {
      "ORDER": "Future -> Present -> Past -> Horizon",
      "VISIBILITY": "Past: Revealed, Future: Hidden"
    },
    "RULE_FLOW_INVERTED": {
      "ORDER": "Past -> Present -> Future -> Horizon",
      "VISIBILITY": "Past: Revealed, Future: Hidden"
    },
    "RULE_FULL_COLUMN_OVERFLOW": {
      "ID": "Paragrafo 121",
      "TRIGGER": "Segment_Enters_Column(count >= 4)",
      "ACTION": "PlayerSelectsAndDestroys(1_Fragment_in_Column)",
      "PROHIBITED": ["PEP_CALCULATION", "RP_CALCULATION", "COMBAT", "COLLISION_DAMAGE"]
    }
  },
  "PHASE_3_ACTIONS": {
    "TEMPORAL_INVERSION": {
      "VOLUNTARY_COST": "1_IT_Damage",
      "ACTION_SEQUENCE": [
        "Invert_Flow_Direction",
        "Swap_Roles(Past, Future)",
        "RECALCULATE_SUPPORT_IMMEDIATELY"
      ]
    },
    "ERIS_CONSTRUCTOR_PASSIVE": {
      "MODIFIER": "REDUCE_COST(VOLUNTARY_INVERSION, 1st_Per_Round) = 0",
      "TARGET": "Eris, Distorsione Vivente"
    }
  },
  "PHASE_5_COLLISION": {
    "CALCULATION": {
      "STEP_1": "Compare(Total_PEP_Sum, Total_RP_Sum_Opponent)",
      "STEP_2": "IF Total_PEP > Total_RP THEN Column_Collapse(Opponent_Fragments_Destroyed)",
      "STEP_3": "IT_Damage = Max(0, (Total_PEP - Total_RP) - Absorption)"
    },
    "STATE_PROPERTIES": {
      "SOLID": "Absorption(-1_IT_Damage)",
      "LIQUID": "Persistence(Return_To_Past_On_Death)",
      "GAS": "Pressure(1_IT_Damage_If_Zero_Damage_Inflicted)",
      "PLASMA": "Discharge(+1_Extra_IT_Damage)"
    }
  }
}
