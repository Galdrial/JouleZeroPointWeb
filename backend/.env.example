# Server
PORT=3000
NODE_ENV=development

# Database Quantum Connection
# Docker: mongodb://joule-mongodb:27017/joule-zero-point
# Local: mongodb://127.0.0.1:27017/joule-zero-point
MONGODB_URI=mongodb://joule-mongodb:27017/joule-zero-point

# Auth
# Cambia questo valore in produzione
JWT_SECRET=change_me_super_secret

# Cards source (opzionale: default già nel codice)
# SHEETS_URL=https://docs.google.com/spreadsheets/.../output=tsv

# OpenAI Assistant
OPENAI_API_KEY=your_openai_api_key_here

# Chat hardening (opzionali)
CHAT_MAX_MESSAGE_LENGTH=1200
CHAT_RATE_WINDOW_MS=60000
CHAT_RATE_MAX_REQUESTS=12

# Admin news management (POST/PUT/DELETE /api/admin/news)
# Imposta una chiave sicura per gestire le news via API
ADMIN_KEY=change_me_admin_key

# Email Transit (Transactional)
# Se usi Gmail, genera una "Password per le app"
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password_here

# Frontend identity (per i link nelle email)
# In produzione: https://joulezeropoint.com
FRONTEND_URL=http://localhost:5173

# Persistence Layer (Cloudinary)
# Formato: cloudinary://API_KEY:API_SECRET@CLOUD_NAME
CLOUDINARY_URL=

# Sender Identity (Optional)
# Indirizzo reale per apparire ai destinatari (es: info@joulezeropoint.com)
EMAIL_FROM=
EMAIL_FROM_NAME=Joule System
